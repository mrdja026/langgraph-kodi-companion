# LLM Inference
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=local
LLM_MODEL=
LLM_TIMEOUT_S=120

# MCP Server Connection
MCP_SERVER_URL=http://localhost:3001/mcp
MCP_TIMEOUT_S=30

# Host File System Roots
WATCHLIST_ROOT=
MEDIA_ROOT=

# Conversation Memory
CHECKPOINT_DB=checkpoints.sqlite

# Agent Behavior
AGENT_RECURSION_LIMIT=25

# LangSmith Observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langgraph-mcp-agent
